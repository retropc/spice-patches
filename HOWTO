export BASE=$(readlink -f .)
export SUFFIX="retropc1."

first:
  apt build-dep libspice-server1 spice-gtk virt-viewer

libspice-server1
  patches:
    - mouse buttons (currently incompatible with master due to qemu patch not being in debian stable)
  instructions:
    mkdir libspice-server1 && cd libspice-server1
    apt source libspice-server1 && cd */
    mkdir -p debian/patches && cp $BASE/spice-server/* debian/patches/ && (cd $BASE/spice-server/ && ls -1) | sort >> debian/patches/series
    dch -l "+$SUFFIX"
    dpkg-buildpackage -us -uc
    cd ..
    rm -f *-{dbgsym,dev}_*.deb
    sudo dpkg -i *.deb
    cd ..

spice-gtk
  patches:
    - mouse buttons 
  instructions:
    mkdir spice-gtk && cd spice-gtk
    apt source libspice-client-gtk-3.0-5 && cd */
    mkdir -p debian/patches && cp $BASE/spice-gtk/* debian/patches/ && (cd $BASE/spice-gtk/ && ls -1) | sort >> debian/patches/series
    dch -l "+$SUFFIX"
    dpkg-buildpackage -us -uc
    cd ..
    rm -f *-dbgsym_*.deb
    sudo dpkg -i *.deb
    cd ..
  other notes:
    (dev packages needed to compile virt-viewer)

virt-viewer:
  patches:
    - autoclipboard disabled (v9 has this as an option that can be set)
    - disable annoying bar at top in fullscreen mode
    - disable menu bap that keeps messing with guest resolution
  instructions:
    mkdir virt-viewer && cd virt-viewer
    apt source virt-viewer && cd */
    mkdir -p debian/patches && cp $BASE/virt-viewer/* debian/patches/ && (cd $BASE/virt-viewer/ && ls -1) | sort >> debian/patches/series
    dch -l "+$SUFFIX"
    dpkg-buildpackage -us -uc
    cd ../..
  notes:
    run out of directory (safety)
    these packages are optional and can be removed:
      apt remove --purge spice-client-gtk
    these packages were only needed for build and can be removed:
      apt remove --purge gir1.2-spiceclientglib-2.0 gir1.2-spiceclientgtk-3.0 libspice-client-glib-2.0-dev libspice-client-gtk-3.0-dev

vd-agent:
  needs:
    - HEAD: c84f9942d7d57463c4790c8e0aad67c096c71415
    - built on fedora 33
  patches:
    - disabling of GetTickCount() measurement in mouse controls for latency
    - button4/5 support
  instructions:
    - see .gitlab-ci.yml


remember to apt-mark hold everything installed!
